# ──────────────────────────────────────────────────
# JeuTaime — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ──────────────────────────────────────────────────

# ── Supabase (optionnel — app fonctionne sans) ────
# Récupérer sur https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Activer Supabase (désactivé par défaut — utilise localStorage)
VITE_USE_SUPABASE=false
